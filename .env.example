# Environment Configuration
ENVIRONMENT=development
PORT=8080
MCP_PORT=8081
LOG_LEVEL=info

# Database Configuration
MONGO_URI=mongodb://localhost:27017/newsroom
REDIS_URI=redis://localhost:6379

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# AI Service API Keys (Get free access at links below)
# 1. Gemini API (FREE): Visit https://aistudio.google.com - No credit card needed
GEMINI_API_KEY=AIzaSy...your_actual_key_here

# 2. Veo API (FREE TRIAL): Get $300 Google Cloud credits at https://cloud.google.com
VEO_API_KEY=your_veo_api_key_here

# 3. Google Imagen API (Optional): For high-quality image generation
# Available through Google Cloud Vertex AI
# Gemini API (above) is used to generate detailed image prompts
# These prompts can be used with Imagen or other image generation APIs
# Setup: https://cloud.google.com/vertex-ai/docs/generative-ai/image/overview
GOOGLE_CLOUD_PROJECT_ID=your_google_cloud_project_id
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json

# Google Custom Search Engine — story image fallback (Creative Commons images)
# 1. Create a CSE at https://programmablesearchengine.google.com (search the whole web, image search on)
# 2. Enable "Custom Search API" in Google Cloud Console and create an API key
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CSE_ID=your_cse_id_here

# 4. D-ID API (Optional): Avatar video generation - Sign up at https://www.d-id.com
DID_API_KEY=your_did_api_key_here

# Content Sources (All FREE - No expensive Twitter API!)

# RSS Feeds (Unlimited, Free) - Already supported by your backend!
RSS_FEEDS=https://www.reutersagency.com/feed/,http://feeds.bbci.co.uk/news/rss.xml,https://techcrunch.com/feed/

# Nitter (Free Twitter alternative via RSS - No API key needed!)
NITTER_INSTANCE=https://nitter.net
NITTER_ACCOUNTS=BBCBreaking,Reuters,TechCrunch

# Reddit API (Free, 60 requests/min, no auth needed)
REDDIT_SUBREDDITS=worldnews,technology,news

# NewsAPI.org (Free tier: 100 requests/day) - Sign up at https://newsapi.org/register
NEWSAPI_KEY=get_free_key_here

# Twitter API (SKIP THIS - Too expensive! Use Nitter instead)
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_BEARER_TOKEN=

# Worker Configuration
WORKER_POOL_SIZE=10
RATE_LIMIT=100

# Avatar Configuration
IDENTITY_IMAGE_URL=https://your-domain.com/avatar/identity.jpg